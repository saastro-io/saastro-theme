---
export interface Props {
  type:
    | 'Organization'
    | 'Person'
    | 'ProfessionalService'
    | 'Article'
    | 'BreadcrumbList'
    | 'WebSite';
  data: Record<string, unknown>;
}

const { type, data } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': type,
  ...data,
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
