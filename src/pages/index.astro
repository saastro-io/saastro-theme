---
import SiteLayout from '../layouts/SiteLayout.astro';
import Hero from '../components/Hero.astro';
import { i18nConfig } from '../i18n/config';

const i18n = i18nConfig.enabled;
const t = i18n ? Astro.locals.t : undefined;
const lp = i18n ? Astro.locals.localePath : (p: string) => p;

const hero = (t as any)?.hero ?? {
  eyebrow: 'Open Source',
  title: ['Build faster', 'with Saastro'],
  subtitle: 'A complete toolkit for web developers. UI components, themes, and CMS — all designed for Astro.',
  primaryCta: 'Get Started',
  secondaryCta: 'View on GitHub',
  stats: [
    { value: '10+', label: 'Components' },
    { value: '100%', label: 'TypeScript' },
    { value: '0kb', label: 'Default JS' },
    { value: 'MIT', label: 'License' },
  ],
};

const meta = (t as any)?.meta ?? { title: 'Saastro Theme', description: 'A modern Astro theme.' };
---

<SiteLayout
  title={meta.title}
  description={meta.description}
  showAnnouncement
  announcement={{ text: 'Saastro Theme is now available', badge: 'NEW', href: '#' }}
>
  <Hero
    eyebrow={hero.eyebrow}
    title={hero.title}
    subtitle={hero.subtitle}
    primaryCta={{ label: hero.primaryCta, href: lp('/blog') }}
    secondaryCta={{ label: hero.secondaryCta, href: 'https://github.com/saastro-io/saastro-hub' }}
    stats={hero.stats}
  />
</SiteLayout>
