---
import { getCollection, render } from 'astro:content';
import { locales, defaultLocale } from '../../../i18n/config';
import { pageOverride, pageKeyFromPath } from '../../../i18n/meta';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Separator } from '@/components/ui/separator';
import { calculateReadingTime } from '../../../lib/reading-time';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return locales.flatMap((locale) =>
    posts.map((post) => ({
      params: { locale: locale === defaultLocale ? undefined : locale, slug: post.id },
    })),
  );
}

const slug = Astro.params.slug as string;
const locale = Astro.locals.lang;
const lp = Astro.locals.localePath;
// Optional per-page SEO override from i18n (Hub Studio SEO panel); falls back
// to the post's own title/description/cover image.
const seo = pageOverride(Astro.locals.t, pageKeyFromPath(Astro.url.pathname, locales));

const allPosts = await getCollection('blog');
const post = allPosts.find((p) => p.id === slug);

if (!post) {
  return Astro.redirect(lp('/blog'));
}

const { Content, headings } = await render(post);
const readingTime = post.data.readingTime ?? calculateReadingTime(post.body ?? '');

const toc = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, label: h.text }));

const formattedDate = new Intl.DateTimeFormat(locale, {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(post.data.date);

const related = allPosts
  .filter((p) => p.id !== slug)
  .filter((p) => p.data.tags?.some((t) => post.data.tags?.includes(t)))
  .slice(0, 3);
---

<SiteLayout
  title={seo.title ?? post.data.title}
  description={seo.description ?? post.data.description}
  image={seo.ogImage ?? post.data.image}
  ogType="article"
>
  <div class="container mx-auto max-w-5xl px-4 py-16">
    <div class="grid lg:grid-cols-[220px_1fr] gap-12">
      {toc.length > 0 && (
        <aside class="hidden lg:block">
          <nav class="sticky top-20">
            <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground mb-4">
              On this page
            </p>
            <ul class="space-y-2">
              {toc.map((item) => (
                <li>
                  <a
                    href={`#${item.id}`}
                    class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <article>
        <header class="mb-10">
          <div class="flex flex-wrap items-center gap-2 mb-4">
            {post.data.tags?.map((tag) => (
              <Badge variant="outline">{tag}</Badge>
            ))}
            <span class="text-xs text-muted-foreground">{readingTime} min read</span>
          </div>
          <h1 class="text-3xl font-bold tracking-tight sm:text-4xl mb-3">
            {post.data.title}
          </h1>
          <p class="text-lg text-muted-foreground mb-4">{post.data.description}</p>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <span>{post.data.author}</span>
            <span>&middot;</span>
            <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
          </div>
        </header>

        <div class="prose dark:prose-invert max-w-none">
          <Content />
        </div>

        <Separator className="my-12" />

        <div class="flex items-center justify-between">
          <Button asChild variant="ghost">
            <a href={lp('/blog')}>&larr; All posts</a>
          </Button>
        </div>

        {related.length > 0 && (
          <div class="mt-12">
            <h2 class="text-lg font-semibold mb-6">Related posts</h2>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {related.map((r) => (
                <a
                  href={lp(`/blog/${r.id}`)}
                  class="group rounded-lg border p-4 transition-colors hover:border-foreground/20"
                >
                  <h3 class="font-medium group-hover:text-foreground transition-colors">
                    {r.data.title}
                  </h3>
                  <p class="text-sm text-muted-foreground line-clamp-2 mt-1">
                    {r.data.description}
                  </p>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>
    </div>
  </div>
</SiteLayout>
