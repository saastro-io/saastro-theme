---
import { locales, defaultLocale } from '../../i18n/config';
import SiteLayout from '../../layouts/SiteLayout.astro';
import Hero from '../../components/Hero.astro';
import Products from '../../components/Products.astro';

export const prerender = true;

// Default locale renders at the root (`/`); other locales are prefixed (`/es/…`).
// The optional rest param `[...locale]` lets one page tree serve both.
export function getStaticPaths() {
  return locales.map((locale) => ({
    params: { locale: locale === defaultLocale ? undefined : locale },
  }));
}

const t = Astro.locals.t;
const lp = Astro.locals.localePath;

const hero = (t as any)?.hero ?? {
  eyebrow: 'Open Source',
  title: ['Build faster', 'with Saastro'],
  subtitle: 'A complete toolkit for web developers. UI components, themes, and CMS — all designed for Astro.',
  primaryCta: 'Get Started',
  secondaryCta: 'View on GitHub',
  stats: [
    { value: '10+', label: 'Components' },
    { value: '100%', label: 'TypeScript' },
    { value: '0kb', label: 'Default JS' },
    { value: 'MIT', label: 'License' },
  ],
};

const products = (t as any)?.products ?? {
  title: 'Everything you need',
  subtitle: 'A complete ecosystem of tools designed specifically for Astro developers.',
  items: [],
};

const meta = t?.meta ?? { title: 'Saastro Theme', description: 'A modern Astro theme.' };
const announcement = t?.announcement ?? { text: 'Saastro Theme is now available', badge: 'NEW' };
---

<SiteLayout
  title={meta.title}
  description={meta.description}
  showAnnouncement
  announcement={{ text: announcement.text, badge: announcement.badge, href: '#' }}
>
  <Hero
    eyebrow={hero.eyebrow}
    title={hero.title}
    subtitle={hero.subtitle}
    primaryCta={{ label: hero.primaryCta, href: lp('/blog') }}
    secondaryCta={{ label: hero.secondaryCta, href: 'https://github.com/saastro-io/saastro-hub' }}
    stats={hero.stats}
    fieldPrefix="hero"
  />

  <Products
    title={products.title}
    subtitle={products.subtitle}
    items={products.items}
    fieldPrefix="products"
  />
</SiteLayout>
