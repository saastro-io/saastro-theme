---
import { getCollection, render } from 'astro:content';
import { locales, defaultLocale } from '../../../i18n/config';
import { pageOverride, pageKeyFromPath } from '../../../i18n/meta';
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const allLegal = await getCollection('legal');
  return allLegal.map((e) => {
    const [loc, ...rest] = e.id.split('/');
    return {
      params: { locale: loc === defaultLocale ? undefined : loc, slug: rest.join('/') },
    };
  });
}

const slug = Astro.params.slug as string;
const locale = Astro.locals.lang;
// Optional per-page SEO override from i18n (editable in the Hub Studio SEO
// panel); falls back to the legal entry's own title/description.
const seo = pageOverride(Astro.locals.t, pageKeyFromPath(Astro.url.pathname, locales));

const allLegal = await getCollection('legal');
const entry = allLegal.find((e) => {
  const parts = e.id.split('/');
  return parts[0] === locale && parts.slice(1).join('/') === slug;
});

if (!entry) {
  return Astro.redirect(`/${locale}`);
}

const { Content, headings } = await render(entry);

// La política de cookies gana un botón de gestión propio: es el camino
// UNIVERSAL de reapertura. Desde cualquier página siempre existe la ruta
// banner-o-footer → política → gestionar, incluso desde las que no llevan
// footer (404/500) o cuyo pie es un componente propio sin el botón (pasa en
// descendientes con footer custom). Id propio y NO `manage-cookies-btn`: ese
// es el del footer, el que exige el contrato, y duplicarlo en la misma página
// sería HTML inválido. El slug lo fija la colección legal.
const isCookiePolicy = slug === 'cookies';
const manageCookiesLabel = Astro.locals.t?.footer?.manageCookies;

const toc = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, label: h.text }));

const lastUpdated = new Intl.DateTimeFormat(locale, {
  month: 'long',
  year: 'numeric',
}).format(entry.data.lastUpdated);
---

<SiteLayout
  title={seo.title ?? entry.data.title}
  description={seo.description ?? entry.data.description}
  image={seo.ogImage}
>
  <div class="container mx-auto max-w-5xl px-4 py-16">
    <div class="grid lg:grid-cols-[220px_1fr] gap-12">
      {toc.length > 0 && (
        <aside class="hidden lg:block">
          <nav class="sticky top-20">
            <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground mb-4">
              On this page
            </p>
            <ul class="space-y-2">
              {toc.map((item) => (
                <li>
                  <a
                    href={`#${item.id}`}
                    class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <article class="prose dark:prose-invert max-w-3xl">
        <h1>{entry.data.title}</h1>
        <p class="text-sm text-muted-foreground">{lastUpdated}</p>
        <Content />

        {isCookiePolicy && manageCookiesLabel && (
          <p class="not-prose mt-10">
            <button
              type="button"
              id="manage-cookies-policy-btn"
              class="inline-flex items-center rounded-md border border-border px-4 py-2 text-sm font-medium hover:bg-muted transition-colors cursor-pointer"
            >
              {manageCookiesLabel}
            </button>
          </p>
        )}
      </article>
    </div>
  </div>

  {/* Mismo patrón que el botón del Footer: listener delegado a document (el
      ClientRouter intercambia el nodo en cada navegación) + pending-flag para
      el click anterior a la hidratación de la isla. */}
  {isCookiePolicy && (
    <script>
      document.addEventListener('click', (e) => {
        const target = e.target as Element | null
        if (target?.closest?.('#manage-cookies-policy-btn')) {
          ;(window as Window & { __cookieReopenPending?: boolean }).__cookieReopenPending = true
          window.dispatchEvent(new CustomEvent('cookie-consent-reopen'))
        }
      })
    </script>
  )}
</SiteLayout>
