---
import { getCollection, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { i18nConfig } from '../../i18n/config';

const { slug } = Astro.params;
const lang = i18nConfig.enabled ? Astro.locals.lang : i18nConfig.defaultLocale;

const allLegal = await getCollection('legal');
const entry = allLegal.find((e) => {
  const parts = e.id.split('/');
  return parts[0] === lang && parts.slice(1).join('/') === slug;
});

if (!entry) {
  return Astro.redirect('/');
}

const { Content, headings } = await render(entry);

const toc = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, label: h.text }));

const lastUpdated = new Intl.DateTimeFormat(lang, {
  month: 'long',
  year: 'numeric',
}).format(entry.data.lastUpdated);

export const prerender = true;

export async function getStaticPaths() {
  const allLegal = await getCollection('legal');
  // Only generate paths for the default locale — middleware handles non-default
  const defaultLocale = i18nConfig.defaultLocale;
  return allLegal
    .filter((e) => e.id.startsWith(`${defaultLocale}/`))
    .map((e) => ({
      params: { slug: e.id.replace(`${defaultLocale}/`, '') },
    }));
}
---

<SiteLayout title={entry.data.title} description={entry.data.description}>
  <div class="container mx-auto max-w-5xl px-4 py-16">
    <div class="grid lg:grid-cols-[220px_1fr] gap-12">
      {/* TOC sidebar */}
      {toc.length > 0 && (
        <aside class="hidden lg:block">
          <nav class="sticky top-20">
            <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground mb-4">
              On this page
            </p>
            <ul class="space-y-2">
              {toc.map((item) => (
                <li>
                  <a
                    href={`#${item.id}`}
                    class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      {/* Content */}
      <article class="prose dark:prose-invert max-w-3xl">
        <h1>{entry.data.title}</h1>
        <p class="text-sm text-muted-foreground">{lastUpdated}</p>
        <Content />
      </article>
    </div>
  </div>
</SiteLayout>
