---
import { getCollection, render } from 'astro:content';
import { i18nConfig, locales } from '../../../i18n/config';
import type { Locale } from '../../../i18n/config';
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const allLegal = await getCollection('legal');
  const nonDefaultLocales = locales.filter((l) => l !== i18nConfig.defaultLocale);
  return nonDefaultLocales.flatMap((locale) =>
    allLegal
      .filter((e) => e.id.startsWith(`${locale}/`))
      .map((e) => ({
        params: { locale, slug: e.id.replace(`${locale}/`, '') },
      }))
  );
}

const { locale, slug } = Astro.params as { locale: Locale; slug: string };

const allLegal = await getCollection('legal');
const entry = allLegal.find((e) => {
  const parts = e.id.split('/');
  return parts[0] === locale && parts.slice(1).join('/') === slug;
});

if (!entry) {
  return Astro.redirect(`/${locale}`);
}

const { Content, headings } = await render(entry);

const toc = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, label: h.text }));

const lastUpdated = new Intl.DateTimeFormat(locale, {
  month: 'long',
  year: 'numeric',
}).format(entry.data.lastUpdated);
---

<SiteLayout title={entry.data.title} description={entry.data.description}>
  <div class="container mx-auto max-w-5xl px-4 py-16">
    <div class="grid lg:grid-cols-[220px_1fr] gap-12">
      {toc.length > 0 && (
        <aside class="hidden lg:block">
          <nav class="sticky top-20">
            <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground mb-4">
              On this page
            </p>
            <ul class="space-y-2">
              {toc.map((item) => (
                <li>
                  <a
                    href={`#${item.id}`}
                    class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <article class="prose dark:prose-invert max-w-3xl">
        <h1>{entry.data.title}</h1>
        <p class="text-sm text-muted-foreground">{lastUpdated}</p>
        <Content />
      </article>
    </div>
  </div>
</SiteLayout>
