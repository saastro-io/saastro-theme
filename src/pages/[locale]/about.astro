---
import { i18nConfig, locales } from '../../i18n/config';
import type { Locale } from '../../i18n/config';
import SiteLayout from '../../layouts/SiteLayout.astro';
import AboutContent from '../../components/AboutContent.astro';

export const prerender = true;

export function getStaticPaths() {
  return locales
    .filter((l) => l !== i18nConfig.defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = Astro.locals.t;

const about = (t as any)?.about ?? {
  title: 'About',
  subtitle: "We're building the tools that make the web better for everyone.",
  mission: {
    title: 'Our Mission',
    description:
      'We believe in open-source software that empowers developers to build beautiful, performant websites without compromise.',
  },
  values: {
    title: 'Our Values',
    items: [
      { title: 'Open Source', description: 'We build in public and share our work freely.' },
      { title: 'Developer First', description: 'Every decision starts with the developer experience.' },
      { title: 'Performance', description: 'Ship less JavaScript, load faster, rank higher.' },
    ],
  },
};

const meta = t?.meta ?? { title: 'Saastro Theme', description: 'A modern Astro theme.' };
---

<SiteLayout title={`${about.title} | ${meta.title}`} description={about.subtitle}>
  <AboutContent
    title={about.title}
    subtitle={about.subtitle}
    missionTitle={about.mission.title}
    missionDescription={about.mission.description}
    valuesTitle={about.values.title}
    valuesItems={about.values.items}
    fieldPrefix="about"
  />
</SiteLayout>
