---
/**
 * BaseLayout — pure HTML shell
 *
 * Handles: SEO meta, OG, Twitter, analytics, dark mode, View Transitions.
 * Does NOT include Header, Footer, or Announcement — use SiteLayout for that.
 *
 * Use this directly when building custom layouts (blog, docs, minimal, etc.)
 */
import '../styles/global.css';
import ApplyColorMode from '../scripts/ApplyColorMode.astro';
import Favicons from '../head/Favicons.astro';
import LocalBusinessJsonLd from '../components/LocalBusinessJsonLd.astro';
import SiteJsonLd from '../components/SiteJsonLd.astro';
import Analytics from '../components/Analytics.astro';
import AnalyticsNoscript from '../components/AnalyticsNoscript.astro';
import GenTracking from '../components/GenTracking.astro';
import { ClientRouter } from 'astro:transitions';
import { i18nConfig } from '../i18n/config';
import { getHreflangEntries } from '../i18n/utils';
import { getSettings } from '../lib/settings';

const settings = getSettings();

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  lang?: string;
  ogType?: string;
  googleSiteVerificationId?: string;
  analytics?: {
    googleAnalyticsId?: string;
    googleTagManagerId?: string;
  };
}

// Use locale from middleware if i18n is enabled, fallback to prop
const localsLang = i18nConfig.enabled ? Astro.locals.lang : undefined;

const {
  title,
  description = settings.metadata.description ?? 'A Saastro theme',
  image = '/og-image.png',
  canonicalUrl,
  lang = localsLang ?? 'en',
  ogType = 'website',
  googleSiteVerificationId,
  analytics = {},
} = Astro.props;

const resolvedGoogleSiteVerificationId =
  googleSiteVerificationId ?? settings.site.googleSiteVerificationId;
const resolvedAnalytics = {
  googleAnalyticsId: analytics.googleAnalyticsId ?? settings.analytics.googleAnalytics.id,
  googleTagManagerId: analytics.googleTagManagerId ?? settings.analytics.googleTagManager.id,
};
const themeColor = settings.site.favicon.colors.theme ?? '#00a897';
const cfWebAnalyticsToken = settings.analytics.cloudflareWebAnalytics?.token ?? '';
// SAASTRO Gen attribution beacon — renders only when the Hub (or the operator)
// wired a Gen workspace into settings.gen. GenTracking itself host-blocks the
// Studio preview + local dev, mirroring the CF Web Analytics guard below.
const genWorkspaceId = settings.gen?.workspaceId ?? '';
const genVertical = settings.gen?.vertical || 'default';
const genConsent = settings.gen?.consent === 'required' ? 'required' : 'none';
// Brand name for og:site_name — from i18n `meta.siteName` (Hub-editable),
// falling back to the build-time settings value.
const siteName =
  (i18nConfig.enabled ? Astro.locals.t?.meta?.siteName : undefined) ??
  settings.site.name ??
  'Saastro';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
const hreflangEntries = i18nConfig.enabled ? getHreflangEntries(Astro.url.pathname) : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {hreflangEntries.map(({ locale, href }) => (
      <link rel="alternate" hreflang={locale} href={`${siteUrl}${href}`} />
    ))}
    {hreflangEntries.length > 0 && (
      <link rel="alternate" hreflang="x-default" href={`${siteUrl}${Astro.url.pathname}`} />
    )}

    <link rel="preconnect" href="/" crossorigin />
    <meta name="theme-color" content={themeColor} />
    <link rel="manifest" href="/manifest.json" />

    <Favicons />
    <SiteJsonLd
      siteUrl={siteUrl}
      siteName={siteName}
      description={description}
      image={ogImage}
    />
    <LocalBusinessJsonLd />
    {resolvedGoogleSiteVerificationId && (
      <meta name="google-site-verification" content={resolvedGoogleSiteVerificationId} />
    )}
    <ApplyColorMode />
    <Analytics
      googleAnalyticsId={resolvedAnalytics.googleAnalyticsId}
      googleTagManagerId={resolvedAnalytics.googleTagManagerId}
    />
    <ClientRouter fallback="swap" />

    <slot name="head" />

    {/* Cloudflare Web Analytics — recommended over GA/GTM. Loads on real
        deployments but is BLOCKED on the Studio preview proxy + local dev
        (where it would fire under the Hub origin and trip the Hub's CSP).
        Only renders when a token is set. The onload shim normalizes
        same-origin URLs to root-relative so the beacon's SPA tracker doesn't
        emit `https:://` on ClientRouter anchor navigations.

        Consentimiento: el beacon es cookieless (defendible sin banner), pero el
        criterio de la flota es consentimiento EXPLÍCITO — mismo patrón que
        GA/GTM en Analytics.astro: no cargar sin analytics===true; si aún no hay
        consentimiento, escuchar cookie-consent-updated e inyectar sin recarga.
        window.__cfBeaconLoaded evita la doble carga (y lo lee el CookieBanner
        para la revocación on→off). */}
    {cfWebAnalyticsToken && (
      <script is:inline define:vars={{ token: cfWebAnalyticsToken }}>
        {
          const h = location.hostname
          const blocked =
            h === 'localhost' ||
            h === '127.0.0.1' ||
            h.endsWith('.saastro.io') ||
            h.endsWith('.saastro.test') ||
            h.endsWith('.local')

          const hasAnalyticsConsent = () => {
            try {
              const match = document.cookie
                .split('; ')
                .find((c) => c.startsWith('cookie_consent='))
              if (!match) return false
              const consent = JSON.parse(decodeURIComponent(match.split('=').slice(1).join('=')))
              return !!consent.analytics
            } catch {
              return false
            }
          }

          const loadBeacon = () => {
            if (window.__cfBeaconLoaded) return
            window.__cfBeaconLoaded = true
            const s = document.createElement('script')
            s.defer = true
            s.src = 'https://static.cloudflareinsights.com/beacon.min.js'
            s.setAttribute('data-cf-beacon', JSON.stringify({ token }))
            s.onload = () => {
              const norm = (u) => {
                if (u == null) return u
                try {
                  const abs = u instanceof URL ? u : new URL(String(u), location.href)
                  if (abs.origin === location.origin) return abs.pathname + abs.search + abs.hash
                } catch (_) {}
                return u
              }
              for (const k of ['pushState', 'replaceState']) {
                const orig = history[k].bind(history)
                history[k] = (state, title, url) => orig(state, title, norm(url))
              }
            }
            document.head.appendChild(s)
          }

          if (!blocked) {
            if (hasAnalyticsConsent()) {
              loadBeacon()
            } else {
              window.addEventListener('cookie-consent-updated', (e) => {
                if (e.detail?.analytics) loadBeacon()
              })
            }
          }
        }
      </script>
    )}

    {/* SAASTRO Gen lead attribution — cookieless page-view beacon + visitor id
        on form submits. Off unless settings.gen.workspaceId is set (the Hub's
        per-site "Gen tracking" toggle writes it). */}
    {genWorkspaceId && (
      <GenTracking workspaceId={genWorkspaceId} vertical={genVertical} consent={genConsent} />
    )}
  </head>

  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <AnalyticsNoscript googleTagManagerId={resolvedAnalytics.googleTagManagerId} />
    <slot />
  </body>
</html>
