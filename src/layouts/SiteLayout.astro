---
/**
 * SiteLayout — standard page layout
 *
 * Extends BaseLayout with Header, Footer, and optional Announcement banner.
 * Use this for all normal site pages (home, about, services, blog index, etc.)
 *
 * To override header/footer per-page:
 *   <SiteLayout ...>
 *     <CustomHeader slot="header" />
 *     Page content
 *     <CustomFooter slot="footer" />
 *   </SiteLayout>
 */
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Announcement } from '../widgets/Announcement/Announcement';
import { CookieBanner } from '../widgets/CookieConsent/CookieBanner';
import { ContactSheetProvider } from '../widgets/ContactSheet';
import { WhatsAppWidget } from '../widgets/WhatsApp';
import { i18nConfig } from '../i18n/config';
import { getLocaleLinks } from '../i18n/utils';
import { getSettings } from '../lib/settings';
import type { Props as BaseProps } from './BaseLayout.astro';
import type { AnnouncementProps } from '../widgets/Announcement/Announcement';

const settings = getSettings();

export interface Props extends BaseProps {
  showAnnouncement?: boolean;
  announcement?: Partial<AnnouncementProps>;
  cookiesPolicyHref?: string;
}

const {
  showAnnouncement = false,
  announcement = {},
  cookiesPolicyHref = '/legal/cookies',
  ...baseProps
} = Astro.props;

// Merge settings-based analytics as defaults; props override via BaseLayout
const basePropsWithDefaults = {
  analytics: {
    googleAnalyticsId: settings.analytics.googleAnalytics.id,
    googleTagManagerId: settings.analytics.googleTagManager.id,
  },
  ...baseProps,
};

const footerSiteName =
  (i18nConfig.enabled ? Astro.locals.t?.meta?.siteName : undefined) ??
  settings.site.name ??
  'Saastro';

// i18n: read from middleware locals when enabled
const i18nEnabled = i18nConfig.enabled;
const lang = i18nEnabled ? Astro.locals.lang : i18nConfig.defaultLocale;
const t = i18nEnabled ? Astro.locals.t : undefined;
const lp = i18nEnabled ? Astro.locals.localePath : (p: string) => p;
const pagePath = Astro.url.pathname;
const normalizedPath =
  i18nEnabled && lang !== i18nConfig.defaultLocale
    ? pagePath.replace(`/${lang}`, '') || '/'
    : pagePath;
const localeLinks = i18nEnabled ? getLocaleLinks(normalizedPath, lang) : [];

// Cookie banner translations: use i18n JSON if available, else English defaults
const cookieT = t?.cookieBanner ?? {
  title: 'We use cookies',
  description: 'We use cookies to improve your experience on our site.',
  policyLinkText: 'Cookie policy',
  acceptAll: 'Accept all',
  rejectAll: 'Reject all',
  customize: 'Customize',
  savePreferences: 'Save preferences',
  essentialLabel: 'Essential',
  essentialDescription: 'Required for the site to function correctly.',
  analyticsLabel: 'Analytics',
  analyticsDescription: 'Help us understand how visitors use the site.',
  personalizationLabel: 'Personalization',
  personalizationDescription: 'Remember your preferences and settings.',
  alwaysActive: 'Always active',
};

// Contact slide-out translations: use i18n JSON if available, else English defaults
const contactT = t?.contactForm ?? {
  sheetTitle: 'Contact us',
  sheetDescription: "Fill in the form below and we'll get back to you as soon as possible.",
  privacyNotice: "We'll use your details based on legitimate interest as set out in our ",
  privacyPolicyLinkText: 'Privacy Policy',
};

// Nav menu: editable i18n array of { key, title }; href resolved from key
// so Studio can add/reorder/rename items without code changes. Unknown
// keys fall back to `/<key>` (e.g. a new "services" item → /services).
const navHrefByKey: Record<string, string> = {
  home: '/',
  about: '/about',
  blog: '/blog',
};
const navItems = t?.nav?.menu ?? [
  { key: 'home', title: 'Home' },
  { key: 'about', title: 'About' },
  { key: 'blog', title: 'Blog' },
];
const navMenu = navItems.map((item) => ({
  title: item.title,
  url: lp(navHrefByKey[item.key] ?? `/${item.key}`),
}));

// Footer legal links: same editable-array pattern, resolved to /legal/* routes.
const legalHrefByKey: Record<string, string> = {
  privacy: '/legal/privacy',
  terms: '/legal/terms',
  cookies: '/legal/cookies',
};
const legalItems = t?.footer?.legal ?? [
  { key: 'privacy', title: 'Privacy Policy' },
  { key: 'terms', title: 'Terms of Service' },
  { key: 'cookies', title: 'Cookie Policy' },
];
const footerLinks = [
  {
    title: t?.footer?.legalLabel ?? 'Legal',
    links: legalItems.map((link) => ({
      text: link.title,
      href: lp(legalHrefByKey[link.key] ?? `/${link.key}`),
    })),
  },
];
---

<BaseLayout {...basePropsWithDefaults}>
  <slot name="head" slot="head" />

  {showAnnouncement && (
    <slot name="announcement">
      <Announcement {...announcement} client:load />
    </slot>
  )}

  <slot name="header">
    <Header menu={navMenu} localeLinks={localeLinks} fieldPrefix="nav" />
  </slot>

  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <slot name="footer">
    <Footer
      links={footerLinks}
      siteName={footerSiteName}
      fieldPrefix="footer"
      manageCookiesLabel={t?.footer?.manageCookies ?? 'Manage cookies'}
    />
  </slot>

  <ContactSheetProvider
    client:only="react"
    locale={lang}
    t={contactT}
    privacyHref={lp('/legal/privacy')}
  />

  <CookieBanner
    cookiesPolicyHref={lp(cookiesPolicyHref)}
    translations={cookieT}
    client:idle
  />

  {t?.whatsapp?.number && (
    <WhatsAppWidget t={t.whatsapp} fieldPrefix="whatsapp" client:load />
  )}
</BaseLayout>

<style>
  /* Ensure body stretches full height for sticky footer */
  :global(body) {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
