---
// Favicon set generated from /public/SVG/icon.svg via scripts/gen-favicons.mjs.
// To rebrand: replace public/SVG/icon.svg with your compact mark and run
//   node scripts/gen-favicons.mjs
// SVG is the primary icon for modern browsers; PNG + ICO are fallbacks.
---
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
